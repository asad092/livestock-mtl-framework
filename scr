```python
import torch
from model import CattleEyeNet
from losses.gradnorm import GradNorm

def train_one_epoch(model, dataloader, optimizer, criterion):
    model.train()
    for images, targets in dataloader:
        optimizer.zero_grad()
        
        preds = model(images)
        # Compute individual losses
        losses = [compute_det_loss(preds['det'], targets['det']),
                  compute_seg_loss(preds['seg'], targets['seg']),
                  compute_pose_loss(preds['pose'], targets['pose'])]
        
        # Apply GradNorm
        total_loss = criterion(losses)
        
        total_loss.backward()
        optimizer.step()

