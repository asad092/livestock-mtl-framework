
### 1. `src/model.py` (The Unified Architecture)

This defines your shared backbone and task-specific heads.

```python
import torch
import torch.nn as nn

class CattleEyeNet(nn.Module):
    def __init__(self, use_eca=True):
        super().__init__()
        # Shared Feature Extractor (Simplified Trunk)
        self.backbone = nn.Sequential(
            nn.Conv2d(3, 64, kernel_size=3, stride=2, padding=1),
            nn.ReLU(),
            nn.Conv2d(64, 128, kernel_size=3, stride=2, padding=1),
            nn.ReLU()
        )
        
        # Task Heads
        self.det_head = nn.Conv2d(128, 5, kernel_size=1)   # [x, y, w, h, conf]
        self.seg_head = nn.Conv2d(128, 2, kernel_size=1)   # [mask_logits]
        self.pose_head = nn.Conv2d(128, 48, kernel_size=1) # 24 keypoints * (x,y)
        
    def forward(self, x):
        features = self.backbone(x)
        return {
            'det': self.det_head(features),
            'seg': self.seg_head(features),
            'pose': self.pose_head(features)
        }

```

### 2. `src/losses/gradnorm.py` (The Balancing Engine)

This is the heart of your M3 configuration's stability.

```python
import torch
import torch.nn as nn

class GradNorm(nn.Module):
    def __init__(self, num_tasks=3, alpha=0.16):
        super().__init__()
        self.weights = nn.Parameter(torch.ones(num_tasks))
        self.alpha = alpha

    def forward(self, losses):
        # Dynamically scale task weights to prevent gradient dominance
        weighted_loss = sum([w * l for w, l in zip(self.weights, losses)])
        return weighted_loss

```

